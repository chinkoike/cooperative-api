        {
            "listen": "test",
            "script": {
                "type": "text/javascript",
                "packages": {},
                "requests": {},
                "exec": [
                    "if (pm.response.code === 200 || pm.response.code === 201) {\r",
                    "    var jsonData = pm.response.json();\r",
                    "    var token = jsonData.token || jsonData.access_token || jsonData.data?.token;\r",
                    "\r",
                    "    if (token) {\r",
                    "        pm.environment.set(\"current_token\", token);\r",
                    "        console.log(\"บันทึก Token เรียบร้อย: \" + token);\r",
                    "    }\r",
                    "}"
                ]
