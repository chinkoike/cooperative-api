  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "packages": {},
        "requests": {},
        "exec": [
          ""
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "packages": {},
        "requests": {},
        "exec": [
          "// ตรวจสอบว่า Status Code เป็น 200 (Login สำเร็จ)\r",
          "if (pm.response.code === 200) {\r",
          "    var jsonData = pm.response.json();\r",
          "    \r",
          "    // ดักไว้หลายๆ ชื่อ ถ้าเจอชื่อไหนตัวแปร token จะได้ค่านั้นไป\r",
          "    var token = jsonData.token || jsonData.access_token || jsonData.data?.token;\r",
          "\r",
          "    if (token) {\r",
          "        // บันทึกลง Environment\r",
          "        pm.environment.set(\"current_token\", token);\r",
          "        console.log(\"บันทึก Token เรียบร้อย: \" + token);\r",
          "    } else {\r",
          "        console.log(\"หา Token ไม่เจอ! ลองเช็คชื่อ Key ใน Response Body ดูครับ\");\r",
          "    }\r",
          "}"
        ]
      }
    }
  ]
