                {
                    "name": "SubmitRequest",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "// 1. ตรวจสอบว่าสร้างสำเร็จ (เช่น 201 Created หรือ 200 OK)\r",
                                    "if (pm.response.code === 201 || pm.response.code === 200) {\r",
                                    "    var jsonData = pm.response.json();\r",
                                    "    \r",
                                    "    // 2. ดึง ID จาก Response (เช็คชื่อ Key ใน JSON ของคุณด้วย เช่น .id หรือ .data.id)\r",
                                    "    var latestId = jsonData.id || jsonData.data.id;\r",
                                    "    \r",
                                    "    if (latestId) {\r",
                                    "        // 3. บันทึก ID ลงใน Environment Variable\r",
                                    "        pm.environment.set(\"latest_request_id\", latestId);\r",
                                    "        console.log(\"บันทึก ID ล่าสุดแล้ว: \" + latestId);\r",
                                    "    }\r",
                                    "}"
                                ],
                                "type": "text/javascript",
                                "packages": {},
                                "requests": {}
                            }
                        }
                    ],
                    "request": {
                        "auth": {
                            "type": "bearer",
                            "bearer": [
                                {
                                    "key": "token",
                                    "value": "{{current_token}}",
                                    "type": "string"
                                }
                            ]
                        },
                        "method": "POST",
                        "header": [],
                        "body": {
